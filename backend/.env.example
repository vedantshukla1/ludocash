# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas — paste your SRV string from Atlas → Connect → Drivers
# Replace <db_password> with your database user password
# Example:
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/ludocash?retryWrites=true&w=majority&appName=Cluster0
MONGODB_URI=mongodb+srv://vedantshuklagola_db_user:<db_password>@cluster0.59ypcom.mongodb.net/ludocash?retryWrites=true&w=majority&appName=Cluster0

# JWT
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRY=7d
REFRESH_EXPIRY=30d

# Admin credentials (hardcoded auth per requirements)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# Google OAuth (for Google Sign-In verification)
GOOGLE_CLIENT_ID=your-google-web-client-id

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret
RAZORPAY_ACCOUNT_NUMBER=your-razorpay-account-number
